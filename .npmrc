# Quarantine new npm releases for 24h before allowing install.
# Defense against supply-chain attacks (malicious releases are typically
# discovered and pulled within hours). See pnpm docs for details.
minimum-release-age=1440

# Don't write a `packageManager` field into package.json. CI pins the
# pnpm version via pnpm/action-setup, and pnpm/action-setup@v6 errors
# out if both are set ("Multiple versions of pnpm specified").
manage-package-manager-versions=false
